# Copy this file to ".env" and fill in the values from the Discord Developer Portal.
# https://discord.com/developers/applications

# Bot token (Application > Bot > Reset Token)
DISCORD_TOKEN=your-bot-token-here

# Application ID (Application > General Information > Application ID)
CLIENT_ID=your-application-id-here

# Server (guild) ID where slash commands should be registered.
# Right-click your server icon in Discord > Copy Server ID (needs Developer Mode on).
# Guild commands update instantly; global commands can take up to an hour.
GUILD_ID=your-server-id-here

# Google Maps Platform API key with the "Places API (New)" enabled.
# Powers the Philippines-only cafe autocomplete on /logcafe.
# Get one at https://console.cloud.google.com/google/maps-apis
# Used by /logcafe (PH cafes) and /logresto (PH restaurants).
# If omitted, those still work but store the name exactly as typed.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# TMDB v3 API key for /logmovie and /logshow autocomplete.
# Free, no billing: https://www.themoviedb.org/settings/api
# If omitted, those still work but store the title exactly as typed.
# (Anime uses the free Jikan API and needs no key.)
TMDB_API_KEY=your-tmdb-v3-api-key-here

# --- Conversational @mention replies -------------------------------------
# Powers the persona chat when you @mention the bot. Uses Claude Code headless.
# Requires the `claude` CLI installed on the host (npm i -g @anthropic-ai/claude-code).
#
# Option A (Claude Max/Pro subscription, no API billing):
#   Run `claude setup-token` on any machine with a browser, paste the token here.
#   NOTE: subscription tokens are intended for personal use — see README.
CLAUDE_CODE_OAUTH_TOKEN=
#
# Option B (pay-per-use API instead): set this and leave the token blank.
# ANTHROPIC_API_KEY=
#
# Optional: model and CLI path. Defaults shown.
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_BIN=claude
#
# Tools the chat may use. Default is web lookup only (for recommendations);
# all task tools (Bash/Write/Edit/Read/etc.) are disabled either way.
# Set to "" or "none" for pure conversation with no web access.
# CHAT_TOOLS=WebSearch WebFetch
