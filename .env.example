# Copy this file to ".env" and fill in the values from the Discord Developer Portal.
# https://discord.com/developers/applications

# Bot token (Application > Bot > Reset Token)
DISCORD_TOKEN=your-bot-token-here

# Application ID (Application > General Information > Application ID)
CLIENT_ID=your-application-id-here

# Server (guild) ID where slash commands should be registered.
# Right-click your server icon in Discord > Copy Server ID (needs Developer Mode on).
# Guild commands update instantly; global commands can take up to an hour.
GUILD_ID=your-server-id-here

# Google Maps Platform API key with the "Places API (New)" enabled.
# Powers the Philippines-only cafe autocomplete on /logcafe.
# Get one at https://console.cloud.google.com/google/maps-apis
# If omitted, /logcafe still works but stores the name exactly as typed.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
